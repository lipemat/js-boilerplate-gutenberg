{
  "extends": "@lipemat/js-boilerplate/config/tsconfig.json",
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "JS Boilerplate Gutenberg",
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "strict": true
